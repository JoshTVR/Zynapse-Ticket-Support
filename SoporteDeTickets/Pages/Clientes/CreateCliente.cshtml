@page
@model SoporteDeTickets.Pages.Clientes.CreateClienteModel
@{
    Layout = "_Layout";
}

<form method="post">
    <h2 class="centered-title">Crear Nuevo Cliente</h2>
    <div>
        <label for="Nombre">Nombre</label>
        <input type="text" id="Nombre" name="Nombre" required />
    </div>
    <div>
        <label for="Email">Email</label>
        <input type="email" id="Email" name="Email" required />
    </div>
    <div>
        <label for="Telefono">Teléfono</label>
        <input type="text" id="Telefono" name="Telefono" required />
    </div>
    <div>
        <label for="FechaRegistro">Fecha de Registro</label>
        <input type="date" id="FechaRegistro" name="FechaRegistro" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
    </div>
    <div>
        <button type="submit">Crear Cliente</button>
    </div>
</form>
